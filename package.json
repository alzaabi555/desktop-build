{
  "name": "student-manager-app",
  "version": "1.0.4",
  "homepage": "./",
  "description": "تطبيق راصد لإدارة حضور وغياب الطلاب - نسخة االوندوز",
  "author": "Mohammed Al-Zaabi",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alzaabi555/desktop-build.git"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').mkdirSync('www', {recursive: true})\"",
    "build": "npm run prebuild && npx esbuild index.tsx --bundle --outfile=www/index.js --format=esm --jsx=automatic --minify --target=es2020 --loader:.js=jsx --loader:.png=dataurl --loader:.mp3=file --define:process.env.NODE_ENV=\\\"'production'\\\" && npx tailwindcss -i ./theme/tokens.css -o ./www/index.css --minify && node ./copy-assets.js",
    "dev": "npm run build && concurrently \"npx tailwindcss -i ./theme/tokens.css -o ./www/index.css --watch\" \"npx esbuild index.tsx --bundle --outfile=www/index.js --format=esm --sourcemap --watch --target=es2020 --loader:.js=jsx --loader:.mp3=file --loader:.png=dataurl --loader:.svg=file --loader:.jpg=file --define:process.env.NODE_ENV=\\\"'development'\\\"\" \"npx serve www\"",
    "electron:dist": "npm run build && electron-builder --publish never"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "react-router-dom": "^6.22.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/clipboard": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "lucide-react": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5",
    "framer-motion": "^11.15.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "html2pdf.js": "^0.10.1",
    "pdfjs-dist": "^3.11.174",
    "dompurify": "^3.0.8",
    "canvg": "^4.0.1",
    "react-to-print": "^3.0.0",
    "electron-updater": "^6.1.7",
    "electron-log": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/assets": "^3.0.5",
    "esbuild": "^0.24.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^9.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tailwindcss": "^3.4.1"
  },
  "build": {
    "publish": null,
    "appId": "com.madrasati.app",
    "productName": "تطبيق راصد",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "www/**/*",
      "electron/**/*",
      "icon.png",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "appx"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "راصد المعلم",
      "language": "1025",
      "displayLanguageSelector": false,
      "installerSidebar": "assets/sidebar.bmp",
      "uninstallerSidebar": "assets/sidebar.bmp",
      "artifactName": "Rased-Setup.${ext}"
    },
    "appx": {
      "applicationId": "RasedApp",
      "identityName": "alzaabi555.Rased555",
      "publisher": "CN=83F2A458-642A-4D83-9CE8-5F30B93D4CC3",
      "publisherDisplayName": "alzaabi555",
      "languages": [
        "ar-SA",
        "en-US"
      ]
    },
    "protocols": [
      {
        "name": "Rased App Protocol",
        "schemes": [
          "rasedapp"
        ]
      }
    ]
  }
}
